# automatic
@Uppercase = [ A B C D E F G H I J L M N O P Q R S T U V W X Y Z
];

# Prefix: Languagesystems
# automatic
languagesystem DFLT dflt;


feature ccmp {
# automatic
lookup ccmp_DFLT_1 {
	@CombiningTopAccents = [acutecomb dieresiscomb dotaccentcomb];
	lookupflag UseMarkFilteringSet @CombiningTopAccents;
	sub i' @CombiningTopAccents by idotless;
	sub j' @CombiningTopAccents by jdotless;
} ccmp_DFLT_1;

} ccmp;
